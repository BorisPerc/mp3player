function findFreeImageNumber($THUMB_DIR) {
    $free = false;
    $img_free_counter = 0;
    while (!$free) {
        $img_free_counter ++;
        if (!file_exists($THUMB_DIR . "/" . $img_free_counter . ".jpg"))
