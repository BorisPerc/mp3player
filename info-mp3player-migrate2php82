    )
    BEGIN
        DECLARE artist_check INT DEFAULT NULL;
        DECLARE album_check INT DEFAULT NULL;
        DECLARE track_check INT DEFAULT NULL;

        SELECT id INTO artist_check FROM artist WHERE title = insert_artist LIMIT 1;
        SELECT al.id INTO album_check FROM album al INNER JOIN artist ar ON al.artist_id = ar.id WHERE ar.title = insert_artist AND al.title = insert_album LIMIT 1;
        SELECT id INTO track_check FROM track WHERE path = insert_path LIMIT 1;

        IF artist_check IS NULL THEN
            INSERT INTO artist (title) VALUES (insert_artist);
            SET artist_check = LAST_INSERT_ID();
